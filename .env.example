# Database Configuration
# PostgreSQL with PGVector extension
DATABASE_URL=postgresql://raguser:ragpass123@localhost:5432/postgres

# OpenAI Configuration (Required)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key
#       OR For local KoboldCpp Configuration
# OPENAI_API_BASE=http://localhost:5002/v1
# OPENAI_API_KEY=sk-dummy-key-for-local-llm


# Model Selection
# Choose which OpenAI model to use for both ingestion and agent
LLM_CHOICE=gpt-4o-mini
#       OR For local KoboldCpp Configuration
# LLM_CHOICE=local-model

# Embedding Model
EMBEDDING_MODEL=text-embedding-3-small
#       OR For local KoboldCpp Configuration
#EMBEDDING_MODEL=all-MiniLM-L6-v2

# Development Settings
LOG_LEVEL=INFO
DEBUG_MODE=false